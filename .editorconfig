root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.{cpp,h,hpp,c,cc,cxx}]
indent_size = 2

[*.{json,jsonc,js,jsx,ts,tsx,css,scss,html,yml,yaml,ps1}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
