{
  "name": "react-mui-opencv-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "npm@10.9.0",
  "engines": {
    "node": ">=20.19.0 <25",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5173",
