{
  "name": "react-mui-opencv-backend",
  "version-string": "0.1.0",
  "dependencies": [
    "cpp-httplib",
    "ixwebsocket",
    "nlohmann-json",
    {
      "name": "opencv4",
      "default-features": false,
      "features": [
        "calib3d",
        "dnn",
        "dshow",
        "jpeg",
        "msmf",
        "png",
        "quirc",
        "thread"
      ]
    },
    "spdlog",
    "sqlite3"
  ]
}
