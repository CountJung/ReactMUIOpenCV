{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Desktop App",
      "type": "cppvsdbg",
      "request": "launch",
      "program": "${workspaceFolder}/backend/out/build/windows-msvc-vcpkg/Debug/ReactMUIOpenCVApp.exe",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}/backend/out/build/windows-msvc-vcpkg/Debug",
      "environment": [],
      "console": "integratedTerminal",
      "preLaunchTask": "debug: prepare backend"
    },
    {
      "name": "Debug Backend",
      "type": "cppvsdbg",
      "request": "launch",
      "program": "${workspaceFolder}/backend/out/build/windows-msvc-vcpkg/Debug/ReactMUIOpenCV.exe",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "console": "integratedTerminal",
      "preLaunchTask": "debug: prepare backend"
    },
    {
      "name": "Debug Backend LAN",
      "type": "cppvsdbg",
      "request": "launch",
      "program": "${workspaceFolder}/backend/out/build/windows-msvc-vcpkg/Debug/ReactMUIOpenCV.exe",
      "args": ["--lan"],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "console": "integratedTerminal",
      "preLaunchTask": "debug: prepare backend"
    },
    {
      "name": "Debug Frontend in Edge",
      "type": "msedge",
      "request": "launch",
      "url": "http://127.0.0.1:5173",
      "webRoot": "${workspaceFolder}/frontend/src",
      "preLaunchTask": "frontend: dev"
    },
    {
      "name": "Debug Remote Access in Edge",
      "type": "msedge",
      "request": "launch",
      "url": "http://127.0.0.1:5173/remote-access",
      "webRoot": "${workspaceFolder}/frontend/src",
      "preLaunchTask": "frontend: dev"
    }
  ],
  "compounds": [
    {
      "name": "Debug Web Mode (Frontend + Backend)",
      "configurations": ["Debug Backend", "Debug Frontend in Edge"],
      "stopAll": true
    },
    {
      "name": "Debug LAN Web Mode",
      "configurations": ["Debug Backend LAN", "Debug Remote Access in Edge"],
      "stopAll": true
    }
  ]
}
